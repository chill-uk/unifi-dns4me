# DNS4ME
# Use either DNS4ME_API_KEY or DNS4ME_DNSMASQ_URL.
DNS4ME_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# DNS4ME_DNSMASQ_URL=https://dns4me.net/api/v2/get_hosts/dnsmasq/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# UniFi Network local API
UNIFI_HOST=https://192.168.1.1
UNIFI_API_KEY=your-unifi-api-key

# The Integration API uses a site id. For single-site installs this is often "default",
# but your UniFi Network app's local API docs are the source of truth.
UNIFI_SITE_ID=default

# Local UniFi consoles often use a self-signed certificate.
UNIFI_SKIP_TLS_VERIFY=true

# UniFi's Forward Domain UI has one DNS server field.
DNS4ME_MAX_SERVERS_PER_DOMAIN=1

# Add dns4me.net as a managed Forward Domain so DNS4ME's check endpoint resolves
# via DNS4ME too.
DNS4ME_INCLUDE_CHECK_DOMAIN=true

# Daily scheduler time used by `unifi-dns4me daemon`.
TZ=Europe/Amsterdam
SYNC_AT=03:15

# Persistent state file used to track entries managed by this tool.
# For Docker, keep this under /data and mount /data as a volume.
STATE_PATH=/data/state.json

# Remove entries that this tool previously managed and DNS4ME later removed.
DELETE_STALE=true

# Set true to run http://check.dns4me.net after sync.
CHECK_AFTER_SYNC=true
CHECK_AFTER_SYNC_DELAY_SECONDS=10

# Heartbeat prerequisite checks used before switching DNS4ME resolvers.
# Internet check uses a TCP connection so the container does not need ping.
HEARTBEAT_ENABLED=true
HEARTBEAT_INTERVAL_SECONDS=300
HEARTBEAT_FAILURES_BEFORE_SWITCH=2
HEARTBEAT_SWITCH_RETRY_SECONDS=600
HEARTBEAT_INTERNET_CHECKS=1.1.1.1:443,8.8.8.8:443,9.9.9.9:443
HEARTBEAT_DNS_CHECK_DOMAINS=cloudflare.com,dns.google,quad9.net
HEARTBEAT_HTTP_CHECK_URLS=https://cloudflare.com/cdn-cgi/trace,https://www.google.com/generate_204,https://dns.quad9.net/

# Logging. Failures and resolver switches are always logged.
# Set HEARTBEAT_LOG_SUCCESS=true if you want a regular "healthy" heartbeat line.
# Set HEARTBEAT_LOG_DETAILS=true if you want each prerequisite check logged.
HEARTBEAT_LOG_SUCCESS=false
HEARTBEAT_LOG_DETAILS=false

# Optional Apprise notifications. Leave NOTIFY_URLS empty/disabled for no notifications.
# Examples: Telegram, Discord, Gotify, Pushover, ntfy, Slack, etc.
# NOTIFY_URLS=tgram://bot_token/chat_id,discord://webhook_id/webhook_token
# NOTIFY_ON_SYNC_ERROR=true
# NOTIFY_ON_SYNC_CHANGES=true
# NOTIFY_ON_SWITCH=true
# NOTIFY_ON_SWITCH_FAILURE=true
# NOTIFY_ON_CHECK_FAIL=true
# NOTIFY_ON_CHECK_RECOVERY=true
